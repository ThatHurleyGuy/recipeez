# SQLite location inside the container. For local non-Docker runs, omit this to use ./data/recipeez.db.
DATABASE_PATH=/app/data/recipeez.db

# Set false to prevent first-run import of root-level Markdown recipes.
AUTO_IMPORT_MARKDOWN=true

# Optional OpenAI-compatible URL import fallback.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

# Optional Vikunja shopping-list sync.
VIKUNJA_URL=
VIKUNJA_API_TOKEN=
VIKUNJA_PROJECT_ID=
VIKUNJA_VIEW_ID=

# ntfy.sh error alerts. Set NTFY_ALERTS_URL=off to disable.
NTFY_ALERTS_URL=https://notify.hurley.io/alerts
NTFY_SERVICE_NAME=recipeez
