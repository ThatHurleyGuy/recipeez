{
  "name": "recipeez",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 4040",
    "build": "next build && npm run prepare:standalone",
    "prepare:standalone": "mkdir -p .next/standalone/.next && cp -R .next/static .next/standalone/.next/static && if [ -d public ]; then cp -R public .next/standalone/public; fi",
    "start": "PORT=${PORT:-4040} HOSTNAME=${HOSTNAME:-127.0.0.1} node .next/standalone/server.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "better-sqlite3": "^12.1.1",
    "next": "^15.5.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
