{
  "name": "recipeez",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 4040",
    "build": "next build && npm run prepare:standalone",
    "prepare:standalone": "mkdir -p .next/standalone/.next && cp -R .next/static .next/standalone/.next/static && if [ -d public ]; then cp -R public .next/standalone/public; fi",
    "start": "PORT=${PORT:-4040} HOSTNAME=${HOSTNAME:-127.0.0.1} node .next/standalone/server.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.19",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3"
  }
}
